# Google Gemini API key (required for generation phase)
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# GitHub token (required for issues fetching)
# Get one at: https://github.com/settings/tokens (only public_repo scope needed)
GITHUB_TOKEN=your-github-token-here

# Stack Exchange API key (optional, raises rate limits)
# Get one at: https://stackapps.com/apps/oauth/register
STACKEXCHANGE_KEY=

# HTTP proxy (required if Gemini API is geo-blocked in your region)
# Example: http://127.0.0.1:7890
HTTPS_PROXY=